{
  "compilerOptions": {
    "forceConsistentCasingInFileNames": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ES2022",
    "strict": true,
    "esModuleInterop": true,
    "lib": ["es2022"],
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "paths": {
      "src/*": ["./src/*"],
      "test/*": ["./test/*"],
      "prisma/*": ["./prisma/*"]
    },
    "types": ["vitest/globals"]
  },
  "include": ["src", "test"]
}
